generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Sector {
  id         Int      @id @default(autoincrement())
  name       String
  price      Float
  totalStock Int
  soldStock  Int      @default(0)
  createdAt  DateTime @default(now())
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  createdAt DateTime @default(now())
}
